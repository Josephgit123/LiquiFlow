rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules (run from this
// firebase/ directory, or add --project <id> if firebase/.firebaserc
// doesn't already point at the right project). Editing this file has
// NO effect on a live project until that command runs — see
// DEPLOYMENT_GUIDE.md's "Firestore Setup" section.
//
// Stricter than the master spec: denies ALL direct client writes, not
// just to the append-only ledger collections. Every write in this app
// goes through the Firebase Admin SDK on the backend (see
// backend/src/config/firebaseAdmin.js) — the client only ever reads.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(merchantId) {
      return isSignedIn() && request.auth.uid == merchantId;
    }

    // Admin sessions are issued out-of-band by the Express backend
    // (signed JWT, verified server-side) and never carry a Firebase
    // Auth session — there is no client-side admin bypass here.
    // Admin-elevated reads/writes happen exclusively via the Admin SDK,
    // which is not subject to these rules.

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /merchants/{merchantId} {
      allow read: if isOwner(merchantId);
      allow write: if false;
    }

    // Mutated in place, but only via server-side Admin SDK writes
    // (DATABASE_SCHEMA.md). Deny all direct client writes.
    match /merchant_balances/{merchantId} {
      allow read: if isOwner(merchantId);
      allow write: if false;
    }

    // Append-only: block update/delete entirely. The sole permitted
    // field mutation (status transitions on CAPTURED -> REFUNDED/DISPUTED)
    // still happens through the Admin SDK server-side, not via a client
    // rule exception, so client create/update/delete all stay denied.
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && resource.data.merchantId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /reserve_vault/{vaultId} {
      allow read: if isSignedIn() && resource.data.merchantId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /system_audit_logs/{logId} {
      allow read: if false;
      allow create, update, delete: if false;
    }

    match /tickets/{ticketId} {
      allow read: if isSignedIn() && resource.data.merchantId == request.auth.uid;
      allow write: if false;

      // Read-only, added for Support Desk's live message thread (Group 6).
      // No rule previously existed for this subcollection at all, which
      // means it was default-denied — a client onSnapshot on
      // tickets/{id}/messages would silently return nothing. get() re-reads
      // the parent ticket rather than duplicating merchantId onto every
      // message doc, so ownership is checked against the single source of
      // truth.
      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          get(/databases/$(database)/documents/tickets/$(ticketId)).data.merchantId == request.auth.uid;
        allow write: if false;
      }
    }

    match /notifications/{notificationId} {
      // Own notifications OR a targetRole-wide MERCHANT broadcast
      // (merchantId: null, per notificationService.js). The original
      // `resource.data.merchantId == request.auth.uid` alone evaluates to
      // false for every broadcast (null != uid), so a merchant's live
      // listener would silently never surface them even though the REST
      // endpoint (via the Admin SDK, not subject to these rules) returns
      // them correctly.
      allow read: if isSignedIn() &&
        (resource.data.merchantId == request.auth.uid ||
         (resource.data.merchantId == null && resource.data.targetRole == 'MERCHANT'));
      allow write: if false;
    }

    match /system_configuration/{docId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
