# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=liquiflow
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Admin console gate — required, no fallback default. Do NOT ship the
# example values below to production; generate long, random values.
# These credentials must never be committed or logged.
ROOT_ADMIN_ACCESS_ID=change-me
ROOT_ADMIN_ACCESS_TOKEN=change-me

# JWT signing — required, no fallback default. Must be a long random
# value in production; never ship a hardcoded/dev secret.
JWT_SECRET=change-me
JWT_EXPIRES_IN=12h

# AI Copilot (server-side only — never expose this key to the client)
GOOGLE_GENERATIVE_AI_API_KEY=change-me
GEMINI_MODEL=gemini-pro

# Reserve engine default
DEFAULT_VAULT_MATURITY_DAYS=3

# Vault-maturity scheduler (60s poll, distributed-lock gated for multi-
# instance deployments — see DEPLOYMENT_GUIDE.md step 4). Defaults to true;
# set to false for tests/CI so no stray background timer fires.
ENABLE_VAULT_SCHEDULER=true
