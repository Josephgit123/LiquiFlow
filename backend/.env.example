# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Firebase Admin SDK — firebaseAdmin.js builds credentials from these
# three values directly (admin.credential.cert), it does NOT read a
# service-account file path. To get them: Firebase Console > Project
# Settings > Service Accounts > Generate new private key. That downloads
# a JSON file — copy its "client_email" field into FIREBASE_CLIENT_EMAIL,
# and its "private_key" field (verbatim, including the literal \n
# sequences and the BEGIN/END lines, wrapped in quotes) into
# FIREBASE_PRIVATE_KEY. Without all three of these set, the server
# throws at startup instead of binding to a port — the most common cause
# of a browser-side "NetworkError when attempting to fetch resource" on
# login is this file not existing yet, since there is no fallback.
FIREBASE_PROJECT_ID=liquiflow
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Admin console gate — required, no fallback default. This is the ONLY
# admin login (entirely separate from Firebase Auth, which merchants
# use) — sign in with ROOT_ADMIN_ACCESS_ID as the "access ID" and
# ROOT_ADMIN_ACCESS_TOKEN as the "access token" on the admin login page.
# Generate real random values for both, e.g. `openssl rand -hex 24` —
# do NOT ship the example values below to production, and never commit
# or log these.
ROOT_ADMIN_ACCESS_ID=change-me
ROOT_ADMIN_ACCESS_TOKEN=change-me

# JWT signing — required, no fallback default. Generate with e.g.
# `openssl rand -hex 32`; never ship a hardcoded/dev secret.
JWT_SECRET=change-me
JWT_EXPIRES_IN=12h

# AI Copilot (server-side only — never expose this key to the client).
# Get a key from https://aistudio.google.com/apikey. Optional: if left
# as "change-me", /api/ai/copilot responds 503 with an explanatory
# message instead of the server failing to start — everything else
# in the app works fine without it.
GOOGLE_GENERATIVE_AI_API_KEY=change-me
GEMINI_MODEL=gemini-1.5-flash

# Reserve engine default
DEFAULT_VAULT_MATURITY_DAYS=3

# Vault-maturity scheduler (60s poll, distributed-lock gated for multi-
# instance deployments — see DEPLOYMENT_GUIDE.md step 4). Defaults to true;
# set to false for tests/CI so no stray background timer fires.
ENABLE_VAULT_SCHEDULER=true
